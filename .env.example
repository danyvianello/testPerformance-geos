# Ruta a Chrome/Chromium si no se detecta (p. ej. Windows: C:\Program Files\Google\Chrome\Application\chrome.exe)
# CHROME_PATH=

# Número de bundle para comparar (se agrega como ?d=BUNDLE_VERSION en las URLs)
# Ejemplo: 123, prod, v2
BUNDLE_VERSION=

# Dejar GEO vacío. test:perf corre las 3 geos. Para una sola: test:perf:argentina | test:perf:espana | test:perf:mexico
GEO=

# --- Más velocidad ---
# Iteraciones por dispositivo: 1-5 (default 3). Con 1 va ~3x más rápido (menos precisión).
# PERF_ITERATIONS=1
# Solo mobile o solo desktop: mobile | desktop | all (default all). Con uno solo ~2x más rápido.
# PERF_FORM_FACTOR=mobile
# Procesar varias URLs en paralelo (1-8 Chromes). Con 2 ~40-50% más rápido. Con 32 GB RAM podés usar 6 u 8.
# PERF_CONCURRENCY=2
